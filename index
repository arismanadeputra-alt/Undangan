                            <option value="4">4 Orang</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] uppercase tracking-widest font-semibold text-stone-600 mb-1">Konfirmasi Kehadiran</label>
                        <div class="flex gap-4 pt-1">
                            <label class="flex items-center gap-2 text-xs text-stone-700 cursor-pointer">
                                <input type="radio" name="Status_Kehadiran" value="Hadir" checked class="accent-sage-600"> Hadir
                            </label>
                            <label class="flex items-center gap-2 text-xs text-stone-700 cursor-pointer">
                                <input type="radio" name="Status_Kehadiran" value="Tidak Hadir" class="accent-sage-600"> Berhalangan
                            </label>
                        </div>
                    </div>
                    <div>
